generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

enum Role {
  ADMIN
  USER
}

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Identity (no email/IMAP fields -- those are on EmailConnection)
  displayName String?
  timezone    String  @default("UTC")
  role        Role    @default(USER)
  theme       String  @default("system") // "light", "dark", or "system"

  // Badge preferences (which sidebar badges to show)
  showImboxBadge      Boolean @default(true)
  showScreenerBadge   Boolean @default(true)
  showFeedBadge       Boolean @default(true)
  showPaperTrailBadge Boolean @default(true)
  showFollowUpBadge   Boolean @default(true)
  showScheduledBadge  Boolean @default(true)

  // Relations
  passkeys          Passkey[]
  emailConnections  EmailConnection[]
  messages          Message[]
  senders           Sender[]
  folders           Folder[]
  sessions          Session[]
  pushSubscriptions PushSubscription[]
  scheduledMessages ScheduledMessage[]
  invitesCreated    Invite[]
  attachments       Attachment[]
}

model Passkey {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // WebAuthn credential data
  credentialId String @unique // base64url encoded credential ID
  publicKey    String // base64url encoded public key (COSE format)
  counter      BigInt @default(0) // signature counter for replay protection
  deviceType   String // "singleDevice" | "multiDevice"
  backedUp     Boolean @default(false)
  transports   String[] // e.g. ["internal", "hybrid"]

  // User-facing label
  friendlyName String? // e.g. "MacBook Pro Touch ID", "iPhone Face ID"

  // User relation
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailConnection {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Email account credentials
  email       String
  displayName String?

  // IMAP configuration
  imapHost String
  imapPort Int    @default(993)

  // SMTP configuration
  smtpHost String
  smtpPort Int    @default(587)

  // Optional "send as" address (e.g. custom domain via iCloud)
  // SMTP auth still uses `email`, but outgoing From header uses this address
  sendAsEmail String?

  // Additional owned email addresses (historical, not for sending)
  aliases String[] @default([])

  // Password stored encrypted with AES-256-GCM (null for OAuth connections)
  encryptedPassword String?

  // OAuth fields (null for password-based connections)
  oauthProvider       String?   // "microsoft" | "google"
  oauthAccessToken    String?   // AES-256-GCM encrypted
  oauthRefreshToken   String?   // AES-256-GCM encrypted
  oauthTokenExpiresAt DateTime?
  oauthError          String?   // Set when token refresh fails; cleared on reconnect

  // Default connection for compose/reply
  isDefault Boolean @default(false)

  // User relation
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relations -- data scoped to this connection
  messages          Message[]
  senders           Sender[]
  folders           Folder[]
  syncState         SyncState?
  scheduledMessages ScheduledMessage[]

  @@unique([userId, email])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================
// SENDER MANAGEMENT (Core Hey.com Feature)
// ============================================

enum SenderStatus {
  PENDING // In screener, awaiting decision
  APPROVED // Approved - emails go to Imbox
  REJECTED // Rejected - emails silently ignored
}

enum SenderCategory {
  IMBOX // Normal approved sender
  FEED // Newsletter/subscription
  PAPER_TRAIL // Transactional (receipts, shipping)
}

model Sender {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Sender identification
  email       String // Normalized email address
  displayName String? // Display name from email headers
  domain      String // Extracted domain for domain-level rules

  // Status and categorization
  status   SenderStatus   @default(PENDING)
  category SenderCategory?

  // Decision metadata
  decidedAt    DateTime? // When approved/rejected
  skippedUntil DateTime? // Hidden from Screener until this time

  // Message count for stats
  messageCount Int @default(0)

  // User relation (kept for cross-connection queries)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Email connection relation (scopes sender to specific account)
  emailConnectionId String
  emailConnection   EmailConnection @relation(fields: [emailConnectionId], references: [id], onDelete: Cascade)

  // Messages from this sender
  messages Message[]

  // Unique per connection (same external sender may email different accounts)
  @@unique([emailConnectionId, email])
  @@index([userId, status])
  @@index([userId, category])
  @@index([emailConnectionId, status])
  @@index([emailConnectionId, category])
  @@index([domain])
}

// ============================================
// FOLDER/MAILBOX
// ============================================

model Folder {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // IMAP folder info
  name      String // e.g., "INBOX", "Sent"
  path      String // Full IMAP path
  delimiter String @default("/")

  // Sync state
  uidValidity   Int?
  highestModSeq BigInt?
  lastSyncedAt  DateTime?

  // Flags
  isSelectable Boolean @default(true)
  hasChildren  Boolean @default(false)

  // Special folder type (RFC 6154)
  specialUse String? // "inbox", "sent", "drafts", "trash", "junk", "archive"

  // User relation (kept for cross-connection queries)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Email connection relation (scopes folder to specific IMAP account)
  emailConnectionId String
  emailConnection   EmailConnection @relation(fields: [emailConnectionId], references: [id], onDelete: Cascade)

  // Messages in this folder
  messages Message[]

  @@unique([emailConnectionId, path])
  @@index([userId, specialUse])
  @@index([emailConnectionId, specialUse])
}

// ============================================
// MESSAGE CACHE
// ============================================

model Message {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // IMAP identifiers
  uid       Int // Message UID within folder
  messageId String? // RFC 2822 Message-ID header

  // Thread grouping
  threadId   String? // Computed thread ID
  inReplyTo  String? // In-Reply-To header
  references String[] // References header

  // Headers
  subject      String?
  fromAddress  String // Raw From address
  fromName     String? // Parsed display name
  toAddresses  String[] // To recipients
  ccAddresses  String[] // CC recipients
  bccAddresses String[] // BCC recipients
  replyTo      String? // Reply-To header

  // Dates
  sentAt     DateTime? // Date header
  receivedAt DateTime // IMAP INTERNALDATE

  // Content (cached)
  textBody String? // Plain text body
  htmlBody String? // HTML body
  snippet  String? // Preview snippet (first ~150 chars)

  // Flags
  isRead     Boolean @default(false)
  isFlagged  Boolean @default(false)
  isDraft    Boolean @default(false)
  isDeleted  Boolean @default(false)
  isAnswered Boolean @default(false)

  // Size and structure
  size           Int?
  hasAttachments Boolean @default(false)

  // Hey.com categorization
  isInImbox      Boolean @default(false) // Visible in Imbox
  isInScreener   Boolean @default(true) // Awaiting screening
  isInFeed       Boolean @default(false) // Newsletter feed
  isInPaperTrail Boolean @default(false) // Transactional
  isArchived     Boolean @default(false) // Moved to archive

  // Snooze
  isSnoozed    Boolean   @default(false)
  snoozedUntil DateTime?

  // Follow-up reminders
  followUpAt    DateTime? // Deadline for follow-up reminder
  followUpSetAt DateTime? // When the reminder was set (for auto-cancel comparison)
  isFollowUp    Boolean   @default(false) // True when reminder has fired

  // Relations
  folderId String
  folder   Folder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  // User relation (kept for efficient cross-connection queries, e.g. unified inbox)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Email connection relation (scopes IMAP operations to the right account)
  emailConnectionId String
  emailConnection   EmailConnection @relation(fields: [emailConnectionId], references: [id], onDelete: Cascade)

  senderId String? // Linked after sender detection
  sender   Sender? @relation(fields: [senderId], references: [id], onDelete: SetNull)

  attachments Attachment[]

  @@unique([folderId, uid])
  @@index([userId, isInScreener])
  @@index([userId, isInImbox, isRead])
  @@index([userId, isInFeed])
  @@index([userId, isInPaperTrail])
  @@index([userId, isArchived])
  @@index([userId, isSnoozed, snoozedUntil])
  @@index([userId, isFollowUp])
  @@index([userId, followUpAt])
  @@index([userId, receivedAt(sort: Desc)])
  @@index([userId, uid])
  @@index([userId, inReplyTo])
  @@index([emailConnectionId])
  @@index([threadId])
  @@index([messageId])
  @@index([senderId])
}

model Attachment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Attachment metadata
  filename    String
  contentType String // MIME type
  size        Int // Size in bytes
  contentId   String? // For inline attachments (CID)

  // IMAP part reference (null for user uploads)
  partId   String? // e.g., "1.2", "2"
  encoding String? // e.g., "base64", "quoted-printable"

  // Content (populated immediately for uploads, lazy for IMAP)
  content Bytes?

  // Message relation (null for uploaded-but-unsent attachments)
  messageId String?
  message   Message? @relation(fields: [messageId], references: [id], onDelete: Cascade)

  // Upload ownership (null for IMAP-synced attachments)
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([contentId])
  @@index([userId, messageId])
}

// ============================================
// SYSTEM SETTINGS
// ============================================

model SystemSettings {
  id                           String  @id @default("singleton")
  signupsEnabled               Boolean @default(true)
  selfServiceAccountManagement Boolean @default(true)
}

// ============================================
// INVITES
// ============================================

model Invite {
  id          String    @id @default(cuid())
  token       String    @unique
  displayName String
  emailHint   String?
  createdBy   String
  creator     User      @relation(fields: [createdBy], references: [id])
  expiresAt   DateTime
  usedAt      DateTime?
  usedBy      String?
  createdAt   DateTime  @default(now())
}

// ============================================
// PUSH NOTIFICATIONS
// ============================================

model PushSubscription {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Web Push subscription data
  endpoint String @unique // Push service URL (always https://)
  p256dh   String // Public key for payload encryption (base64url)
  auth     String // Auth secret (base64url)

  // User relation
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================
// SYNC STATE
// ============================================

model SyncState {
  id String @id @default(cuid())

  // Per-connection sync state (each email syncs independently)
  emailConnectionId String          @unique
  emailConnection   EmailConnection @relation(fields: [emailConnectionId], references: [id], onDelete: Cascade)

  // Last successful full sync
  lastFullSync DateTime?

  // Sync status
  isSyncing     Boolean   @default(false)
  syncStartedAt DateTime?
  syncError     String?
  lastSyncLog   String?
}

// ============================================
// SCHEDULED MESSAGES (Send Later)
// ============================================

enum ScheduledMessageStatus {
  PENDING
  SENDING
  SENT
  FAILED
  CANCELLED
}

model ScheduledMessage {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Scheduling
  scheduledFor DateTime // Always UTC
  status       ScheduledMessageStatus @default(PENDING)

  // Retry tracking
  attempts         Int       @default(0)
  nextRetryAt      DateTime? // null until first failure
  sendingStartedAt DateTime? // For stale-lock recovery (> 5min = stuck)
  smtpMessageId    String?   // Recorded after send for idempotency
  error            String?   // Sanitized error message

  // Email content (encrypted at rest via crypto.ts)
  to       String
  subject  String  @default("")
  textBody String  @default("")
  htmlBody String?

  // Reply context (null for new compose)
  inReplyToMessageId String?
  references         String?

  // Attachment IDs (references Attachment table, linked at send time)
  attachmentIds String[] @default([])

  // Ownership
  userId            String
  user              User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailConnectionId String
  emailConnection   EmailConnection @relation(fields: [emailConnectionId], references: [id], onDelete: Cascade)

  @@index([userId, status, scheduledFor])
  @@index([status, scheduledFor])
  @@index([status, nextRetryAt])
}
