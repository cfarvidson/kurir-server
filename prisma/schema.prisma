generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// USER & AUTHENTICATION
// ============================================

model User {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Identity (no email/IMAP fields -- those are on EmailConnection)
  displayName String?
  timezone    String  @default("UTC")

  // Relations
  passkeys         Passkey[]
  emailConnections EmailConnection[]
  messages         Message[]
  senders          Sender[]
  folders          Folder[]
  sessions         Session[]
}

model Passkey {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // WebAuthn credential data
  credentialId String @unique // base64url encoded credential ID
  publicKey    String // base64url encoded public key (COSE format)
  counter      BigInt @default(0) // signature counter for replay protection
  deviceType   String // "singleDevice" | "multiDevice"
  backedUp     Boolean @default(false)
  transports   String[] // e.g. ["internal", "hybrid"]

  // User-facing label
  friendlyName String? // e.g. "MacBook Pro Touch ID", "iPhone Face ID"

  // User relation
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model EmailConnection {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Email account credentials
  email       String
  displayName String?

  // IMAP configuration
  imapHost String
  imapPort Int    @default(993)

  // SMTP configuration
  smtpHost String
  smtpPort Int    @default(587)

  // Optional "send as" address (e.g. custom domain via iCloud)
  // SMTP auth still uses `email`, but outgoing From header uses this address
  sendAsEmail String?

  // Additional owned email addresses (historical, not for sending)
  aliases String[] @default([])

  // Password stored encrypted with AES-256-GCM
  encryptedPassword String

  // Default connection for compose/reply
  isDefault Boolean @default(false)

  // User relation
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relations -- data scoped to this connection
  messages  Message[]
  senders   Sender[]
  folders   Folder[]
  syncState SyncState?

  @@unique([userId, email])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ============================================
// SENDER MANAGEMENT (Core Hey.com Feature)
// ============================================

enum SenderStatus {
  PENDING // In screener, awaiting decision
  APPROVED // Approved - emails go to Imbox
  REJECTED // Rejected - emails silently ignored
}

enum SenderCategory {
  IMBOX // Normal approved sender
  FEED // Newsletter/subscription
  PAPER_TRAIL // Transactional (receipts, shipping)
}

model Sender {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Sender identification
  email       String // Normalized email address
  displayName String? // Display name from email headers
  domain      String // Extracted domain for domain-level rules

  // Status and categorization
  status   SenderStatus   @default(PENDING)
  category SenderCategory @default(IMBOX)

  // Decision metadata
  decidedAt DateTime? // When approved/rejected

  // Message count for stats
  messageCount Int @default(0)

  // User relation (kept for cross-connection queries)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Email connection relation (scopes sender to specific account)
  emailConnectionId String
  emailConnection   EmailConnection @relation(fields: [emailConnectionId], references: [id], onDelete: Cascade)

  // Messages from this sender
  messages Message[]

  // Unique per connection (same external sender may email different accounts)
  @@unique([emailConnectionId, email])
  @@index([userId, status])
  @@index([userId, category])
  @@index([emailConnectionId, status])
  @@index([emailConnectionId, category])
  @@index([domain])
}

// ============================================
// FOLDER/MAILBOX
// ============================================

model Folder {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // IMAP folder info
  name      String // e.g., "INBOX", "Sent"
  path      String // Full IMAP path
  delimiter String @default("/")

  // Sync state
  uidValidity   Int?
  highestModSeq BigInt?
  lastSyncedAt  DateTime?

  // Flags
  isSelectable Boolean @default(true)
  hasChildren  Boolean @default(false)

  // Special folder type (RFC 6154)
  specialUse String? // "inbox", "sent", "drafts", "trash", "junk", "archive"

  // User relation (kept for cross-connection queries)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Email connection relation (scopes folder to specific IMAP account)
  emailConnectionId String
  emailConnection   EmailConnection @relation(fields: [emailConnectionId], references: [id], onDelete: Cascade)

  // Messages in this folder
  messages Message[]

  @@unique([emailConnectionId, path])
  @@index([userId, specialUse])
  @@index([emailConnectionId, specialUse])
}

// ============================================
// MESSAGE CACHE
// ============================================

model Message {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // IMAP identifiers
  uid       Int // Message UID within folder
  messageId String? // RFC 2822 Message-ID header

  // Thread grouping
  threadId   String? // Computed thread ID
  inReplyTo  String? // In-Reply-To header
  references String[] // References header

  // Headers
  subject      String?
  fromAddress  String // Raw From address
  fromName     String? // Parsed display name
  toAddresses  String[] // To recipients
  ccAddresses  String[] // CC recipients
  bccAddresses String[] // BCC recipients
  replyTo      String? // Reply-To header

  // Dates
  sentAt     DateTime? // Date header
  receivedAt DateTime // IMAP INTERNALDATE

  // Content (cached)
  textBody String? // Plain text body
  htmlBody String? // HTML body
  snippet  String? // Preview snippet (first ~150 chars)

  // Flags
  isRead     Boolean @default(false)
  isFlagged  Boolean @default(false)
  isDraft    Boolean @default(false)
  isDeleted  Boolean @default(false)
  isAnswered Boolean @default(false)

  // Size and structure
  size           Int?
  hasAttachments Boolean @default(false)

  // Hey.com categorization
  isInImbox      Boolean @default(false) // Visible in Imbox
  isInScreener   Boolean @default(true) // Awaiting screening
  isInFeed       Boolean @default(false) // Newsletter feed
  isInPaperTrail Boolean @default(false) // Transactional
  isArchived     Boolean @default(false) // Moved to archive

  // Snooze
  isSnoozed    Boolean   @default(false)
  snoozedUntil DateTime?

  // Relations
  folderId String
  folder   Folder @relation(fields: [folderId], references: [id], onDelete: Cascade)

  // User relation (kept for efficient cross-connection queries, e.g. unified inbox)
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Email connection relation (scopes IMAP operations to the right account)
  emailConnectionId String
  emailConnection   EmailConnection @relation(fields: [emailConnectionId], references: [id], onDelete: Cascade)

  senderId String? // Linked after sender detection
  sender   Sender? @relation(fields: [senderId], references: [id], onDelete: SetNull)

  attachments Attachment[]

  @@unique([folderId, uid])
  @@index([userId, isInScreener])
  @@index([userId, isInImbox, isRead])
  @@index([userId, isInFeed])
  @@index([userId, isInPaperTrail])
  @@index([userId, isArchived])
  @@index([userId, isSnoozed, snoozedUntil])
  @@index([userId, receivedAt(sort: Desc)])
  @@index([userId, uid])
  @@index([userId, inReplyTo])
  @@index([emailConnectionId])
  @@index([threadId])
  @@index([messageId])
  @@index([senderId])
}

model Attachment {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  // Attachment metadata
  filename    String
  contentType String // MIME type
  size        Int // Size in bytes
  contentId   String? // For inline attachments (CID)

  // IMAP part reference (for lazy loading)
  partId   String // e.g., "1.2", "2"
  encoding String? // e.g., "base64", "quoted-printable"

  // Message relation
  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([contentId])
}

// ============================================
// SYNC STATE
// ============================================

model SyncState {
  id String @id @default(cuid())

  // Per-connection sync state (each email syncs independently)
  emailConnectionId String          @unique
  emailConnection   EmailConnection @relation(fields: [emailConnectionId], references: [id], onDelete: Cascade)

  // Last successful full sync
  lastFullSync DateTime?

  // Sync status
  isSyncing     Boolean   @default(false)
  syncStartedAt DateTime?
  syncError     String?

  @@index([emailConnectionId])
}
