---
import BaseLayout from "./BaseLayout.astro";
import DocsSidebar from "../components/DocsSidebar.astro";
import { getCollection } from "astro:content";

interface Props {
  title: string;
  description: string;
  currentSlug: string;
}

function stripExt(id: string) {
  return id.replace(/\.mdx?$/, "");
}

const { title, description, currentSlug } = Astro.props;
const base = import.meta.env.BASE_URL;

const docs = await getCollection("docs");
const sorted = docs.sort((a, b) => a.data.order - b.data.order);
const currentIndex = sorted.findIndex((doc) => doc.id === currentSlug);
const prev = currentIndex > 0 ? sorted[currentIndex - 1] : null;
const next = currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null;
---

<BaseLayout title={`${title} - Kurir Docs`} description={description}>
  <DocsSidebar currentSlug={currentSlug} />

  <!-- Mobile header -->
  <div
    class="sticky top-0 z-30 flex items-center border-b border-surface-200/60 bg-white/95 px-4 py-3 backdrop-blur-xs md:hidden"
  >
    <button
      id="sidebar-toggle"
      class="mr-3 rounded-md p-1.5 text-ink-light transition-colors hover:bg-surface-100 hover:text-ink"
      aria-label="Toggle navigation"
    >
      <svg
        width="20"
        height="20"
        viewBox="0 0 24 24"
        fill="none"
        stroke="currentColor"
        stroke-width="2"
        stroke-linecap="round"
        stroke-linejoin="round"
      >
        <line x1="3" y1="6" x2="21" y2="6"></line>
        <line x1="3" y1="12" x2="21" y2="12"></line>
        <line x1="3" y1="18" x2="21" y2="18"></line>
      </svg>
    </button>
    <a
      href={base}
      class="text-sm font-bold tracking-tight text-ink"
    >
      Kurir
    </a>
    <span class="mx-2 text-ink-muted">/</span>
    <span class="text-sm text-ink-light">{title}</span>
  </div>

  <!-- Mobile overlay -->
  <div
    id="sidebar-overlay"
    class="fixed inset-0 z-30 hidden bg-black/20 backdrop-blur-xs md:hidden"
  >
  </div>

  <!-- Main content -->
  <main class="docs-content">
    <article class="prose mx-auto max-w-content px-6 py-12 md:py-16">
      <slot />
    </article>

    <!-- Prev / Next navigation -->
    <nav
      class="mx-auto flex max-w-content items-stretch gap-4 border-t border-surface-200 px-6 py-8"
    >
      {
        prev ? (
          <a
            href={`${base}docs/${stripExt(prev.id)}`}
            class="group flex flex-1 flex-col rounded-lg border border-surface-200 px-4 py-3 transition-colors hover:border-accent/40 hover:bg-surface-50"
          >
            <span class="text-xs font-medium uppercase tracking-wider text-ink-muted">
              Previous
            </span>
            <span class="mt-1 text-sm font-medium text-ink group-hover:text-accent-dark">
              {prev.data.title}
            </span>
          </a>
        ) : (
          <div class="flex-1" />
        )
      }
      {
        next ? (
          <a
            href={`${base}docs/${stripExt(next.id)}`}
            class="group flex flex-1 flex-col items-end rounded-lg border border-surface-200 px-4 py-3 text-right transition-colors hover:border-accent/40 hover:bg-surface-50"
          >
            <span class="text-xs font-medium uppercase tracking-wider text-ink-muted">
              Next
            </span>
            <span class="mt-1 text-sm font-medium text-ink group-hover:text-accent-dark">
              {next.data.title}
            </span>
          </a>
        ) : (
          <div class="flex-1" />
        )
      }
    </nav>
  </main>

  <script>
    const toggle = document.getElementById("sidebar-toggle");
    const sidebar = document.getElementById("docs-sidebar");
    const overlay = document.getElementById("sidebar-overlay");

    function openSidebar() {
      sidebar?.classList.add("is-open");
      overlay?.classList.remove("hidden");
    }

    function closeSidebar() {
      sidebar?.classList.remove("is-open");
      overlay?.classList.add("hidden");
    }

    toggle?.addEventListener("click", () => {
      if (sidebar?.classList.contains("is-open")) {
        closeSidebar();
      } else {
        openSidebar();
      }
    });

    overlay?.addEventListener("click", closeSidebar);
  </script>

  <style>
    .docs-content {
      margin-left: 260px;
      min-height: 100vh;
    }

    @media (max-width: 768px) {
      .docs-content {
        margin-left: 0;
      }
    }
  </style>
</BaseLayout>
