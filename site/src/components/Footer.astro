---
const base = import.meta.env.BASE_URL;
const year = new Date().getFullYear();
---

<footer class="border-t border-surface-200 bg-surface-50 px-6 py-12">
  <div class="mx-auto max-w-landing">
    <div class="flex flex-col items-center gap-4 text-center">
      <p class="text-sm text-ink-light">
        Kurir is open source under the <a href="https://github.com/cfarvidson/kurir-server/blob/main/LICENSE" target="_blank" rel="noopener noreferrer" class="underline hover:text-ink">O'Saasy license</a>.
      </p>
      <div class="flex items-center gap-6">
        <a
          href="https://github.com/cfarvidson/kurir-server"
          target="_blank"
          rel="noopener noreferrer"
          class="text-sm text-ink-muted transition-colors hover:text-ink"
        >
          GitHub
        </a>
        <a
          href={`${base}docs/getting-started`}
          class="text-sm text-ink-muted transition-colors hover:text-ink"
        >
          Documentation
        </a>
      </div>
      <p class="text-xs text-ink-muted">
        &copy; {year} Kurir
      </p>
    </div>
  </div>
</footer>
