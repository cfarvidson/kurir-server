---
import { getCollection } from "astro:content";

interface Props {
  currentSlug: string;
}

function stripExt(id: string) {
  return id.replace(/\.mdx?$/, "");
}

const { currentSlug } = Astro.props;
const base = import.meta.env.BASE_URL;

const docs = await getCollection("docs");
const sorted = docs.sort((a, b) => a.data.order - b.data.order);
---

<aside id="docs-sidebar" class="docs-sidebar">
  <div class="px-4 py-6">
    <a
      href={base}
      class="mb-6 block text-lg font-bold tracking-tight text-ink"
    >
      Kurir
    </a>
    <nav>
      <h3
        class="mb-3 text-xs font-semibold uppercase tracking-wider text-ink-muted"
      >
        Documentation
      </h3>
      <ul class="space-y-0.5">
        {
          sorted.map((doc) => {
            const isActive = doc.id === currentSlug;
            return (
              <li>
                <a
                  href={`${base}docs/${stripExt(doc.id)}`}
                  class:list={[
                    "block rounded-md px-3 py-2 text-sm transition-colors",
                    isActive
                      ? "bg-accent/10 font-medium text-accent-dark"
                      : "text-ink-light hover:bg-surface-100 hover:text-ink",
                  ]}
                  aria-current={isActive ? "page" : undefined}
                >
                  {doc.data.title}
                </a>
              </li>
            );
          })
        }
      </ul>
    </nav>
    <div class="mt-8 border-t border-surface-200 pt-4">
      <a
        href="https://github.com/cfarvidson/kurir-server"
        target="_blank"
        rel="noopener noreferrer"
        class="flex items-center gap-2 text-sm text-ink-muted transition-colors hover:text-ink"
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="currentColor"
          aria-hidden="true"
        >
          <path
            d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0024 12c0-6.63-5.37-12-12-12z"
          ></path>
        </svg>
         GitHub
      </a>
    </div>
  </div>
</aside>

<style>
  .docs-sidebar {
    position: fixed;
    top: 0;
    left: 0;
    bottom: 0;
    width: 260px;
    overflow-y: auto;
    border-right: 1px solid #e7e5e4;
    background: #fafaf9;
    z-index: 40;
    transition: transform 0.2s ease;
  }

  @media (max-width: 768px) {
    .docs-sidebar {
      transform: translateX(-100%);
    }

    .docs-sidebar.is-open {
      transform: translateX(0);
    }
  }
</style>
