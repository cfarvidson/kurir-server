---
const base = import.meta.env.BASE_URL;
const installCmd =
  "curl -fsSL https://raw.githubusercontent.com/cfarvidson/kurir-server/main/install.sh | bash";
---

<section class="bg-surface-50 px-6 py-24 md:py-32">
  <div class="mx-auto max-w-landing">
    <div class="mx-auto max-w-2xl">
      <h2
        class="text-center text-3xl font-bold tracking-tight text-ink md:text-4xl"
      >
        Up and running in one command
      </h2>

      <div
        class="group relative mt-12 overflow-hidden rounded-lg border border-surface-200 bg-white"
      >
        <div
          class="flex items-center justify-between border-b border-surface-200 px-4 py-2.5"
        >
          <span class="font-mono text-xs text-ink-muted">terminal</span>
          <button
            id="install-copy-btn"
            class="flex items-center gap-1.5 rounded-md px-2.5 py-1 text-xs font-medium text-ink-muted transition-colors hover:bg-surface-200 hover:text-ink"
            data-cmd={installCmd}
          >
            <svg
              width="14"
              height="14"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect x="9" y="9" width="13" height="13" rx="2" ry="2"></rect>
              <path d="M5 15H4a2 2 0 01-2-2V4a2 2 0 012-2h9a2 2 0 012 2v1"
              ></path>
            </svg>
            <span class="copy-label">Copy</span>
          </button>
        </div>
        <div class="p-5">
          <pre
            class="overflow-x-auto font-mono text-sm leading-relaxed text-ink"><span class="select-none text-ink-muted">$ </span>{installCmd}</pre>
        </div>
      </div>

      <ul class="mt-10 space-y-3 text-ink-light">
        <li class="flex items-start gap-3">
          <span class="mt-0.5 text-accent" aria-hidden="true">&#10003;</span>
          <span>Generates secure secrets and environment config</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-0.5 text-accent" aria-hidden="true">&#10003;</span>
          <span>Configures HTTPS with automatic certificates</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-0.5 text-accent" aria-hidden="true">&#10003;</span>
          <span>Pulls Docker images and starts all services</span>
        </li>
        <li class="flex items-start gap-3">
          <span class="mt-0.5 text-accent" aria-hidden="true">&#10003;</span>
          <span>Sets up PostgreSQL and Redis automatically</span>
        </li>
      </ul>

      <div class="mt-10 text-center">
        <a
          href={`${base}/docs/getting-started`}
          class="inline-flex items-center gap-1 text-sm font-medium text-accent transition-colors hover:text-accent-dark"
        >
          Read the installation guide
          <span aria-hidden="true">&rarr;</span>
        </a>
      </div>
    </div>
  </div>
</section>

<script>
  function initCopyButton(btn: HTMLButtonElement) {
    btn.addEventListener("click", async () => {
      const cmd = btn.dataset.cmd;
      if (!cmd) return;
      try {
        await navigator.clipboard.writeText(cmd);
        const label = btn.querySelector(".copy-label");
        if (label) {
          label.textContent = "Copied!";
          setTimeout(() => {
            label.textContent = "Copy";
          }, 2000);
        }
      } catch {
        /* clipboard API unavailable */
      }
    });
  }

  const installBtn = document.getElementById(
    "install-copy-btn",
  ) as HTMLButtonElement | null;
  if (installBtn) initCopyButton(installBtn);
</script>
