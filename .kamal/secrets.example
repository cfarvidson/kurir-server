# Copy to .kamal/secrets and fill in real values.
# Values are read from your shell environment by default ($VAR syntax).
# You can also use command substitution: $(op read ...)

# Registry password (GitHub Container Registry personal access token)
KAMAL_REGISTRY_PASSWORD=$KAMAL_REGISTRY_PASSWORD

# Database (use the internal 127.0.0.1 address since postgres runs on same host)
DATABASE_URL=postgresql://kurir:YOUR_PASSWORD@127.0.0.1:5432/kurir
POSTGRES_PASSWORD=YOUR_PASSWORD

# Application secrets (generate with: openssl rand -base64 32)
NEXTAUTH_SECRET=$NEXTAUTH_SECRET
ENCRYPTION_KEY=$ENCRYPTION_KEY
