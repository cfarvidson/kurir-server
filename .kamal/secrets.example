# Secrets defined here are available for reference under registry/password, env/secret, builder/secrets,
# and accessories/*/env/secret in config/deploy.yml. All secrets should be pulled from either
# password manager, ENV, or a file. DO NOT ENTER RAW CREDENTIALS HERE! This file needs to be safe for git.

# Docker Registry
DOCKER_REGISTRY_TOKEN=$DOCKER_REGISTRY_TOKEN

# Database
DATABASE_URL=$KAMAL_DATABASE_URL
POSTGRES_PASSWORD=$KAMAL_POSTGRES_PASSWORD

# Application secrets
AUTH_SECRET=$KAMAL_AUTH_SECRET
ENCRYPTION_KEY=$KAMAL_ENCRYPTION_KEY
VAPID_PRIVATE_KEY=$KAMAL_VAPID_PRIVATE_KEY

# Redis
REDIS_URL=$KAMAL_REDIS_URL

# OAuth (optional — omit to disable OAuth sign-in buttons)
MICROSOFT_CLIENT_ID=$KAMAL_MICROSOFT_CLIENT_ID
MICROSOFT_CLIENT_SECRET=$KAMAL_MICROSOFT_CLIENT_SECRET
GOOGLE_CLIENT_ID=$KAMAL_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_SECRET=$KAMAL_GOOGLE_CLIENT_SECRET
