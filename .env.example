# =============================================================================
# Kurir — Environment Configuration
# =============================================================================
# For self-hosted deployments, you only need to set KURIR_DOMAIN.
# All secrets auto-generate on first boot if not provided.
# =============================================================================

# --- Required for production ---
# Your domain (e.g., mail.example.com). Derives NEXTAUTH_URL, WEBAUTHN_RP_ID.
# KURIR_DOMAIN="mail.example.com"

# --- Optional: admin email (used for VAPID contact / Let's Encrypt) ---
# KURIR_ADMIN_EMAIL="admin@example.com"

# --- Database ---
# Default: postgresql://kurir:kurir@localhost:5432/kurir
# DATABASE_URL="postgresql://kurir:kurir@localhost:5432/kurir"

# --- Secrets (auto-generated on first boot if missing) ---
# AUTH_SECRET=""
# ENCRYPTION_KEY=""
# ENCRYPTION_SALT="kurir-salt"

# --- VAPID keys for push notifications (auto-generated on first boot) ---
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=""
# VAPID_PRIVATE_KEY=""

# --- Redis (optional, defaults to localhost:6379) ---
# REDIS_URL="redis://localhost:6379"

# --- OAuth providers (optional, for Microsoft/Google IMAP OAuth) ---
# MICROSOFT_CLIENT_ID=""
# MICROSOFT_CLIENT_SECRET=""
# GOOGLE_CLIENT_ID=""
# GOOGLE_CLIENT_SECRET=""

# --- WebAuthn overrides (derived from KURIR_DOMAIN by default) ---
# WEBAUTHN_RP_NAME="Kurir"
# WEBAUTHN_RP_ID="mail.example.com"
