# =============================================================================
# Kurir — Production Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the values before running:
#   docker compose -f docker-compose.production.yml up -d

# -----------------------------------------------------------------------------
# Domain (required)
# -----------------------------------------------------------------------------
# Your server's public domain name. Caddy auto-provisions HTTPS via Let's Encrypt.
DOMAIN=mail.example.com

# -----------------------------------------------------------------------------
# Database (required)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
POSTGRES_PASSWORD=
# POSTGRES_USER=kurir    # default: kurir
# POSTGRES_DB=kurir      # default: kurir

# -----------------------------------------------------------------------------
# Redis (required)
# -----------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
REDIS_PASSWORD=

# -----------------------------------------------------------------------------
# Application Secrets (required)
# -----------------------------------------------------------------------------
# Generate each with: openssl rand -base64 32
NEXTAUTH_SECRET=
ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# WebAuthn (optional)
# -----------------------------------------------------------------------------
# WEBAUTHN_RP_NAME=Kurir  # Display name shown during passkey registration

# -----------------------------------------------------------------------------
# Push Notifications (optional)
# -----------------------------------------------------------------------------
# Generate VAPID keys with: npx web-push generate-vapid-keys
# VAPID_PRIVATE_KEY=
# NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# -----------------------------------------------------------------------------
# OAuth Providers (optional — omit to disable OAuth sign-in buttons)
# -----------------------------------------------------------------------------
# Microsoft (Azure AD)
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=

# Google
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
